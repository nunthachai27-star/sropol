# KK-LRMS Production Environment
# Copy this to .env and fill in the values:
#   cp .env.production.example .env

# ─── PostgreSQL ───
POSTGRES_DB=kklrms
POSTGRES_USER=kklrms
POSTGRES_PASSWORD=<generate-strong-password>
POSTGRES_PORT=5432

# ─── Redis ───
# docker-compose provides redis://redis:6379 by default.
REDIS_URL=redis://redis:6379
REDIS_KEY_PREFIX=kk-lrms

# ─── Application ───
APP_PORT=3000
# Public port nginx listens on (reverse proxy entry). TLS is terminated upstream.
WEB_PORT=8080
# Serve the app under a URL sub-path. Leave EMPTY for a root deployment.
# For https://surintelehealth.com/sr-lrms set:
#   NEXT_PUBLIC_BASE_PATH=/sr-lrms
#   NEXTAUTH_URL=https://surintelehealth.com/sr-lrms
# NOTE: NEXT_PUBLIC_BASE_PATH is baked in at build time — rebuild the image
# after changing it (docker compose build app).
NEXT_PUBLIC_BASE_PATH=
# Default MOPH province code (32=Surin, 40=Khon Kaen). Blank = code default 32.
# Build-time (rebuild image after changing). Admins can still switch the live
# province at runtime under /admin · จังหวัดหลัก.
NEXT_PUBLIC_DEFAULT_PROVINCE_CODE=
NEXTAUTH_URL=https://kk-lrms.bmscloud.in.th
NEXTAUTH_SECRET=<generate-with: openssl rand -base64 32>
ENCRYPTION_KEY=<generate-with: openssl rand -hex 32>
# Public origin HOSxP webhooks should POST back to (include the sub-path).
# Defaults to window.location.origin; set when behind the sub-path proxy:
#   NEXT_PUBLIC_KK_LRMS_PUBLIC_URL=https://surintelehealth.com/sr-lrms
NEXT_PUBLIC_KK_LRMS_PUBLIC_URL=

# ─── BMS Session API ───
# Hospital codes granted ADMIN role on BMS login (comma-separated). 99999 (the
# provincial-admin sandbox) is always included; this env only ADDS to it.
ADMIN_HCODES=
BMS_VALIDATE_URL=https://hosxp.net/phapi/PasteJSON
DEV_HOSPITAL_TUNNEL_URL=
DEV_AUTH_BYPASS=false

# ─── ProviderID OAuth2 (readonly login) ───
NEXT_PUBLIC_MOPH_OAUTH_CLIENT_ID=<moph-oauth-client-id>
MOPH_OAUTH_CLIENT_SECRET=<moph-oauth-client-secret>
PROVIDER_API_CLIENT_ID=<provider-api-client-id>
PROVIDER_API_SECRET_KEY=<provider-api-secret-key>
NEXT_PUBLIC_MOPH_OAUTH_URL=https://moph.id.th
NEXT_PUBLIC_PROVIDER_API_URL=https://provider.id.th
