# Database (local PostgreSQL cache)
POSTGRES_PASSWORD="<set-a-strong-password>"
DATABASE_URL="postgresql://kklrms:<password>@localhost:5432/kklrms?schema=public"

# Database driver (alternatives to a real Postgres server)
# - USE_SQLITE=true → file-backed SQLite at SQLITE_PATH (default: dev.sqlite)
# - USE_PGLITE=true → in-process Postgres via @electric-sql/pglite,
#                     persisted at PGLITE_PATH (default: ./.pglite-data)
# Either flag, when set, takes precedence over DATABASE_URL.
# USE_PGLITE="true"
# PGLITE_PATH="./.pglite-data"

# Redis cache / online-user presence
# Leave unset for `npm run dev` to use the built-in in-process memory store.
# Set REDIS_URL when you want local dev to share cache/presence across processes.
# REDIS_URL="redis://localhost:6379"
# REDIS_KEY_PREFIX="kk-lrms"

# Auth (NextAuth.js)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<generate-with: openssl rand -base64 32>"

# BMS Session API (authentication validation endpoint)
BMS_VALIDATE_URL="https://hosxp.net/phapi/PasteJSON"

# PDPA Encryption Key (AES-256 hex key for patient name/CID)
ENCRYPTION_KEY="<generate-with: openssl rand -hex 32>"

# Development: Auto-configure test hospital on startup
DEV_HOSPITAL_TUNNEL_URL="<your-hospital-tunnel-url>"

# Development: Skip BMS authentication (accepts any session ID as ADMIN)
# DEV_AUTH_BYPASS="true"

# Development: Override the user CID in the offline-dev fallback identity.
# Used to test ADMIN_ALLOWED_CIDS without a real BMS session. Only takes
# effect when DEV_AUTH_BYPASS=true AND BMS is unreachable.
# DEV_USER_CID="3320500282121"

# Admin allow-list — comma-separated เลขบัตรประชาชน 13 หลัก of users who may
# access /admin and /api/admin. Empty / unset = role-only gate (back-compat).
# Non-empty = require user_cid (from BMS user_info.user_cid) to be on the
# list, even when role=ADMIN or DEV_AUTH_BYPASS=true. Strongly recommended
# for production — the role check alone is too weak (any BMS user whose
# position contains "director" / "ผู้อำนวยการ" is auto-promoted to ADMIN).
# ADMIN_ALLOWED_CIDS="3320500282121,1100500012345"

# ProviderID OAuth2 (readonly login)
NEXT_PUBLIC_MOPH_OAUTH_CLIENT_ID="<moph-oauth-client-id>"
MOPH_OAUTH_CLIENT_SECRET="<moph-oauth-client-secret>"
PROVIDER_API_CLIENT_ID="<provider-api-client-id>"
PROVIDER_API_SECRET_KEY="<provider-api-secret-key>"
NEXT_PUBLIC_MOPH_OAUTH_URL="https://moph.id.th"
NEXT_PUBLIC_PROVIDER_API_URL="https://provider.id.th"
